# Copy to filofax/.env or /opt/filofax/.env and adjust values

FILOFAX_HOST=0.0.0.0
FILOFAX_PORT=8002
FILOFAX_RELOAD=false
FILOFAX_CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
FILOFAX_DEFAULT_USER_ID=default
FILOFAX_DATA_DIR=data
# FILOFAX_DATABASE_URL=sqlite:///data/filofax.db

# Local AI runtime — swap model/provider without code or schema changes
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b
AI_BASE_URL=http://127.0.0.1:11434
# Legacy aliases still accepted:
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=120

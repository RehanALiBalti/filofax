# Copy to /opt/filofax/.env on the server

FILOFAX_HOST=127.0.0.1
FILOFAX_PORT=8002
FILOFAX_RELOAD=false
FILOFAX_CORS_ORIGINS=http://filofax.buzzwaretech.com,https://filofax.buzzwaretech.com,http://65.108.236.135,http://65.108.236.135/filofax
FILOFAX_DEFAULT_USER_ID=default
FILOFAX_DATA_DIR=/opt/filofax/data

# Local Ollama (shared with JAMS / CV Builder)
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b
AI_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=120

# Voice notes — local Whisper (no paid STT)
VOICE_ENABLED=true
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Leave empty for auto language (Urdu/English/mixed)
# WHISPER_LANGUAGE=ur
VOICE_MAX_BYTES=15728640

# Firestore reminders — collection Reminders, filter by userId
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=/opt/filofax/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIRESTORE_DATABASE_ID=(default)
FIRESTORE_REMINDERS_COLLECTION=Reminders
FIRESTORE_REMINDER_TIMEZONE=Europe/Vienna


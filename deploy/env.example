# Copy to /opt/filofax/.env on the server

FILOFAX_HOST=127.0.0.1
FILOFAX_PORT=8002
FILOFAX_RELOAD=false
FILOFAX_CORS_ORIGINS=http://filofax.buzzwaretech.com,https://filofax.buzzwaretech.com,http://65.108.236.135,http://65.108.236.135/filofax
FILOFAX_DEFAULT_USER_ID=default
FILOFAX_DATA_DIR=/opt/filofax/data

# Local Ollama (shared with JAMS / CV Builder)
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b
AI_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=120

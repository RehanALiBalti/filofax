# =============================================================================
# Firebase for Filofax reminders (TEMPLATE — do not commit real secrets)
# =============================================================================
# Collection: myReminders
# Query: documents where userId == <path / ?userid= >
# API: GET /api/reminders/{userId}
#
# 1) Firebase Console → Project Settings → Service accounts → Generate new key
# 2) Save on server: /opt/filofax/secrets/firebase-service-account.json (chmod 600)
# 3) Copy these lines into /opt/filofax/.env
# =============================================================================

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
GOOGLE_APPLICATION_CREDENTIALS=/opt/filofax/secrets/firebase-service-account.json
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_REMINDERS_COLLECTION=myReminders
FIRESTORE_REMINDER_TIMEZONE=Europe/Vienna

# Document shape written by Filofax (native mobile schema):
# {
#   "id": "001D9B1E-5494-4E43-9584-E027599BBC93",
#   "image": "",
#   "insertDate": 1763326219904,
#   "isArchive": false,
#   "isDairy": true,
#   "isSent": false,
#   "notes": "Title text",
#   "sdate": 1780117200000,
#   "sdisplaydate": 1780117200000,
#   "sdisplaymonth": "05",
#   "sdisplayyear": "2026",
#   "smonth": "05",
#   "ssdate": "20260530",
#   "ssdisplaydate": "20260530",
#   "status": false,
#   "syear": "2026",
#   "timeZone": "Europe/Vienna",
#   "title": "Title text",
#   "type": "To Do",
#   "userId": "<from ?userid=>"
# }

[Unit]
Description=Filofax AI Event Assistant (FastAPI)
After=network-online.target ollama.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/filofax
EnvironmentFile=-/opt/filofax/.env
Environment=HOME=/opt/filofax/.home
ExecStart=/opt/filofax/.venv/bin/uvicorn backend.main:app --host 127.0.0.1 --port 8002
Restart=always
RestartSec=5
StartLimitIntervalSec=0
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
